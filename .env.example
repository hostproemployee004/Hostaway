# ── Hostaway Credentials ──────────────────────────────────────────
# Get these from: Hostaway Dashboard > Settings > Hostaway API
HOSTAWAY_ACCOUNT_ID=your_account_id_here
HOSTAWAY_API_KEY=your_api_key_here

# ── MCP Server Protection ─────────────────────────────────────────
# Anyone with this key can use your MCP server — make it long & random
MCP_API_KEY=make_a_long_random_secret_here

# ── Server Port ───────────────────────────────────────────────────
PORT=3000
